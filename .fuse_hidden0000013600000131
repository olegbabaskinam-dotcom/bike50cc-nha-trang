<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Палитры для байкового сайта</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Manrope',system-ui,sans-serif;background:#EEF1F0;color:#12211D;padding:26px 18px 50px}
.head{max-width:1180px;margin:0 auto 22px}
.head h1{font-family:'Space Grotesk';font-size:26px;letter-spacing:-.5px}
.head p{color:#5B6770;font-size:15px;margin-top:5px}
.board{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.tile{background:#fff;border:1px solid #DFE6E3;border-radius:18px;padding:14px;position:relative;box-shadow:0 6px 22px rgba(16,50,42,.06)}
.tnum{position:absolute;top:-11px;left:-11px;width:34px;height:34px;border-radius:50%;background:#12211D;color:#fff;font-family:'Space Grotesk';font-weight:700;display:flex;align-items:center;justify-content:center;font-size:16px;z-index:3}
.thead{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;padding:2px 4px}
.tname{font-family:'Space Grotesk';font-weight:700;font-size:15.5px}
.tref{font-size:11.5px;color:#8A948F}

/* MINI MOCK */
.mock{border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.06);background:var(--bg)}
.m-head{display:flex;align-items:center;gap:6px;padding:9px 11px;background:var(--surf);border-bottom:1px solid rgba(0,0,0,.06)}
.m-logo{font-family:'Space Grotesk';font-weight:700;font-size:11px;color:var(--txt);letter-spacing:.4px}
.m-logo b{color:var(--acc)}
.m-nav{flex:1;display:flex;gap:8px;margin-left:6px}
.m-nav i{width:20px;height:5px;border-radius:3px;background:var(--mut);opacity:.5}
.m-btn{background:var(--acc);color:var(--btnT,#fff);font-size:8.5px;font-weight:800;padding:5px 9px;border-radius:6px}
.m-hero{padding:16px 13px;background:var(--heroBg,var(--bg));position:relative}
.m-h1{font-family:'Space Grotesk';font-weight:700;font-size:16px;line-height:1.1;color:var(--heroT,var(--txt))}
.m-h1 span{color:var(--acc)}
.m-sub{font-size:9px;color:var(--heroM,var(--mut));margin:5px 0 9px;max-width:150px}
.m-cta{display:inline-block;background:var(--acc);color:var(--btnT,#fff);font-size:8.5px;font-weight:800;padding:6px 11px;border-radius:6px}
.m-cta.alt{background:transparent;color:var(--heroT,var(--txt));border:1px solid var(--mut);margin-left:5px}
.m-cards{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:11px 13px 13px;background:var(--bg)}
.m-card{background:var(--surf);border:1px solid rgba(0,0,0,.06);border-radius:8px;overflow:hidden}
.m-ph{height:44px;display:flex;align-items:flex-end;padding:5px}
.m-tag{background:var(--acc2,var(--acc));color:var(--tagT,#fff);font-size:6.5px;font-weight:800;padding:2px 5px;border-radius:5px}
.m-cb{padding:6px 7px}
.m-nm{font-size:8px;font-weight:700;color:var(--txt)}
.m-pr{font-family:'Space Grotesk';font-size:9.5px;font-weight:700;color:var(--txt);margin-top:1px}

.swatches{display:flex;gap:6px;margin-top:11px;padding:0 4px}
.swatches i{width:26px;height:26px;border-radius:7px;border:1px solid rgba(0,0,0,.08)}
.pick{margin-top:11px;text-align:center;font-size:12px;font-weight:800;color:#0B7E6C;background:#EAF5F2;padding:8px;border-radius:9px;cursor:pointer;border:1px solid #CFE7E0}
.pick:hover{background:#0FA48C;color:#fff}
@media(max-width:900px){.board{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.board{grid-template-columns:1fr}}
</style>
</head>
